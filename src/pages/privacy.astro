---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import { t } from '../i18n/ui';

const lang = 'en' as const;
---

<Layout title={t(lang, 'privacy.title')} lang={lang}>
  <nav class="nav">
    <div class="container">
      <a href="/" class="nav-logo">
        <img src="/logo_dark.svg" alt="mi8" width="48" height="32" class="logo-light-theme" />
        <img src="/logo_light.svg" alt="mi8" width="48" height="32" class="logo-dark-theme" />
      </a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">&#9776;</button>
      <ul class="nav-links" id="nav-links">
        <li><a href="/#services">Services</a></li>
        <li><a href="/#use-cases">Use cases</a></li>
        <li><a href="/#sovereignty">Our approach</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/#contact">Contact us</a></li>
        <li class="nav-links-cta"><a href="/assessment" class="btn btn-primary">Talk to our agent</a></li>
      </ul>
      <div class="nav-right">
        <LanguagePicker lang={lang} path="/privacy" />
        <ThemeToggle />
        <a href="/assessment" class="btn btn-primary">Talk to our agent</a>
      </div>
    </div>
  </nav>

  <article class="blog-post">
    <div class="container">
      <a href="/" class="blog-back">&larr; Back to home</a>
      <header class="blog-post-header">
        <h1>{t(lang, 'privacy.heading')}</h1>
        <p class="blog-post-meta">{t(lang, 'privacy.lastUpdated')}</p>
      </header>
      <div class="blog-post-content">
        <h2>Who we are</h2>
        <p>mi8 SRL, Chauss&eacute;e de Namur 31/5, 1457 Walhain, Belgium. VAT BE 0535.711.105. Contact: <a href="mailto:contact@mi8.be">contact@mi8.be</a>.</p>

        <h2>AI Readiness Assessment</h2>
        <p>Our assessment agent runs entirely on sovereign infrastructure located in the EU, powered by open-source models. Here is how data is handled during the assessment:</p>
        <ul>
          <li><strong>No conversation storage.</strong> Your chat messages are processed in real time to generate responses. They are not logged, stored, or used for training. When you close the page, the conversation is gone.</li>
          <li><strong>No personal data collected.</strong> We do not ask for your name, email, or any identifying information during the chat. No cookies or tracking pixels are used on the assessment page.</li>
          <li><strong>IP addresses.</strong> Your IP address is processed temporarily in server memory for rate limiting (preventing abuse). It is not logged to disk and is discarded when the server restarts.</li>
          <li><strong>Sharing is your choice.</strong> At the end of the assessment, you may choose to email the results to mi8 or copy them to your clipboard. This action is entirely optional and initiated by you&mdash;we do not automatically receive any conversation data.</li>
        </ul>

        <h2>Contact form</h2>
        <p>The contact form on our homepage is processed by <a href="https://formspree.io" target="_blank" rel="noopener noreferrer">Formspree</a> (based in the United States). When you submit the contact form, your name, email, company, and message are transmitted to Formspree and forwarded to us via email. Formspree acts as a data processor under their <a href="https://formspree.io/legal/privacy-policy" target="_blank" rel="noopener noreferrer">privacy policy</a>. We use this data solely to respond to your inquiry.</p>

        <h2>Website hosting</h2>
        <p>This website is hosted on <a href="https://pages.github.com" target="_blank" rel="noopener noreferrer">GitHub Pages</a>. GitHub may collect technical logs (IP addresses, browser type) as described in their <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" target="_blank" rel="noopener noreferrer">privacy statement</a>. We use Google Fonts for typography, which involves requests to Google's servers when loading the page.</p>

        <h2>Your rights</h2>
        <p>Under the GDPR, you have the right to access, rectify, erase, restrict, or port your personal data, and to object to its processing. Since we collect minimal data, most of these rights are satisfied by design. For any request, contact us at <a href="mailto:contact@mi8.be">contact@mi8.be</a>.</p>

        <h2>Changes</h2>
        <p>We may update this policy as our services evolve. The date at the top of this page indicates the last revision.</p>
      </div>
    </div>
  </article>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-info">
          <p class="footer-company">mi8 SRL</p>
          <p>Chauss&eacute;e de Namur 31/5, 1457 Walhain, Belgium<br />VAT BE 0535.711.105</p>
        </div>
        <div class="footer-links">
          <a href="mailto:contact@mi8.be">contact@mi8.be</a>
          <a href="https://www.linkedin.com/company/mi8/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/mi8" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 mi8 SRL. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script is:inline>
    document.getElementById('nav-toggle').addEventListener('click', function () {
      document.getElementById('nav-links').classList.toggle('open');
    });
    document.querySelectorAll('#nav-links a').forEach(function (link) {
      link.addEventListener('click', function () {
        document.getElementById('nav-links').classList.remove('open');
      });
    });
  </script>
</Layout>
