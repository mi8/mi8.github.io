---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import HeroNetwork from '../../components/HeroNetwork.astro';
import { getCollection } from 'astro:content';
import { t } from '../../i18n/ui';

const lang = 'fr' as const;
const posts = (await getCollection('blog-fr'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title={t(lang, 'meta.title')} lang={lang}>
  <Nav lang={lang} path="/" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>
    <div class="container">
      <div class="hero-layout">
        <div class="hero-content">
          <p class="section-label">{t(lang, 'hero.label')}</p>
          <h1>{t(lang, 'hero.title.before')}<span class="accent">{t(lang, 'hero.title.accent')}</span>{t(lang, 'hero.title.after')}</h1>
          <p>{t(lang, 'hero.description')}</p>
          <div class="hero-actions">
            <a href="/fr/assessment" class="btn btn-primary">{t(lang, 'hero.cta')}</a>
            <a href="#use-cases" class="btn btn-outline">{t(lang, 'hero.secondary')}</a>
          </div>
        </div>
        <HeroNetwork />
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services">
    <div class="container">
      <p class="section-label">{t(lang, 'services.label')}</p>
      <h2 class="section-title">{t(lang, 'services.title')}</h2>
      <p class="section-subtitle">{t(lang, 'services.subtitle')}</p>
      <div class="cards-grid">
        <div class="card">
          <span class="card-icon">&#9670;</span>
          <h3>{t(lang, 'services.build.title')}</h3>
          <p>{t(lang, 'services.build.description')}</p>
        </div>
        <div class="card">
          <span class="card-icon">&#9881;</span>
          <h3>{t(lang, 'services.run.title')}</h3>
          <p>{t(lang, 'services.run.description')}</p>
        </div>
        <div class="card">
          <span class="card-icon">&#9741;</span>
          <h3>{t(lang, 'services.improve.title')}</h3>
          <p>{t(lang, 'services.improve.description')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section id="use-cases" style="background: var(--bg-secondary);">
    <div class="container">
      <p class="section-label">{t(lang, 'useCases.label')}</p>
      <h2 class="section-title">{t(lang, 'useCases.title')}</h2>
      <p class="section-subtitle">{t(lang, 'useCases.subtitle')}</p>
      <div class="use-cases-grid">
        <div class="use-case">
          <h3>{t(lang, 'useCases.invoice.title')}</h3>
          <p>{t(lang, 'useCases.invoice.description')}</p>
        </div>
        <div class="use-case">
          <h3>{t(lang, 'useCases.onboarding.title')}</h3>
          <p>{t(lang, 'useCases.onboarding.description')}</p>
        </div>
        <div class="use-case">
          <h3>{t(lang, 'useCases.support.title')}</h3>
          <p>{t(lang, 'useCases.support.description')}</p>
        </div>
        <div class="use-case">
          <h3>{t(lang, 'useCases.compliance.title')}</h3>
          <p>{t(lang, 'useCases.compliance.description')}</p>
        </div>
        <div class="use-case">
          <h3>{t(lang, 'useCases.pipeline.title')}</h3>
          <p>{t(lang, 'useCases.pipeline.description')}</p>
        </div>
        <div class="use-case">
          <h3>{t(lang, 'useCases.knowledge.title')}</h3>
          <p>{t(lang, 'useCases.knowledge.description')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sovereignty -->
  <section id="sovereignty">
    <div class="container">
      <p class="section-label">{t(lang, 'sovereignty.label')}</p>
      <h2 class="section-title">{t(lang, 'sovereignty.title')}</h2>
      <p class="section-subtitle">{t(lang, 'sovereignty.subtitle')}</p>
      <div class="cards-grid">
        <div class="card">
          <span class="card-icon">&#9618;</span>
          <h3>{t(lang, 'sovereignty.infra.title')}</h3>
          <p>{t(lang, 'sovereignty.infra.description')}</p>
        </div>
        <div class="card">
          <span class="card-icon">&#9735;</span>
          <h3>{t(lang, 'sovereignty.oss.title')}</h3>
          <p>{t(lang, 'sovereignty.oss.description')}</p>
        </div>
        <div class="card">
          <span class="card-icon">&#9740;</span>
          <h3>{t(lang, 'sovereignty.privacy.title')}</h3>
          <p>{t(lang, 'sovereignty.privacy.description')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section id="process" style="background: var(--bg-secondary);">
    <div class="container">
      <p class="section-label text-center">{t(lang, 'process.label')}</p>
      <h2 class="section-title text-center">{t(lang, 'process.title')}</h2>
      <p class="section-subtitle text-center mx-auto">{t(lang, 'process.subtitle')}</p>
      <div class="process-grid">
        <div class="process-step">
          <div class="process-number">01</div>
          <h3>{t(lang, 'process.discover.title')}</h3>
          <p>{t(lang, 'process.discover.description')}</p>
        </div>
        <div class="process-step">
          <div class="process-number">02</div>
          <h3>{t(lang, 'process.build.title')}</h3>
          <p>{t(lang, 'process.build.description')}</p>
        </div>
        <div class="process-step">
          <div class="process-number">03</div>
          <h3>{t(lang, 'process.deploy.title')}</h3>
          <p>{t(lang, 'process.deploy.description')}</p>
        </div>
        <div class="process-step">
          <div class="process-number">04</div>
          <h3>{t(lang, 'process.improve.title')}</h3>
          <p>{t(lang, 'process.improve.description')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="container">
      <p class="section-label">{t(lang, 'about.label')}</p>
      <h2 class="section-title">{t(lang, 'about.title')}</h2>
      <div class="about-content">
        <p>{t(lang, 'about.p1')}</p>
        <p>{t(lang, 'about.p2')}</p>
        <p>{t(lang, 'about.p3')}</p>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section id="blog" style="background: var(--bg-secondary);">
    <div class="container">
      <p class="section-label">{t(lang, 'blog.label')}</p>
      <h2 class="section-title">{t(lang, 'blog.title')}</h2>
      <p class="section-subtitle">{t(lang, 'blog.subtitle')}</p>
      <div class="blog-grid">
        {posts.map((post) => (
          <a href={`/fr/blog/${post.slug}`} class="blog-card">
            <p class="blog-card-date">
              {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="blog-card-link">{t(lang, 'blog.readMore')}</span>
          </a>
        ))}
      </div>
      <div class="blog-more">
        <a href="/fr/blog" class="btn btn-outline">{t(lang, 'blog.allPosts')}</a>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="cta-section">
    <div class="container">
      <div class="contact-layout">
        <div class="contact-text">
          <h2>{t(lang, 'cta.title')}</h2>
          <p class="section-subtitle">{t(lang, 'cta.description')}</p>
        </div>
        <form class="contact-form" action="https://formspree.io/f/mgolpyor" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="name">{t(lang, 'cta.name')}</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">{t(lang, 'cta.email')}</label>
              <input type="email" id="email" name="email" required />
            </div>
          </div>
          <div class="form-group">
            <label for="company">{t(lang, 'cta.company')}</label>
            <input type="text" id="company" name="company" />
          </div>
          <div class="form-group">
            <label for="message">{t(lang, 'cta.message')}</label>
            <textarea id="message" name="message" rows="4" placeholder={t(lang, 'cta.message')} required></textarea>
          </div>
          <button type="submit" class="btn btn-primary contact-submit">{t(lang, 'cta.button')}</button>
          <p class="contact-feedback" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-info">
          <p class="footer-company">{t(lang, 'footer.company')}</p>
          <p>{t(lang, 'footer.address')}<br />{t(lang, 'footer.vat')}</p>
        </div>
        <div class="footer-links">
          <a href="mailto:contact@mi8.be">contact@mi8.be</a>
          <a href="https://www.linkedin.com/company/mi8/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/mi8" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="/fr/privacy">Confidentialit&eacute;</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{t(lang, 'footer.copyright')}</p>
      </div>
    </div>
  </footer>

  <script is:inline>
    (function () {
      var form = document.querySelector('.contact-form');
      if (!form) return;
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = form.querySelector('.contact-submit');
        var feedback = form.querySelector('.contact-feedback');
        var originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Envoi en cours\u2026';
        feedback.textContent = '';
        feedback.className = 'contact-feedback';
        fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' }
        }).then(function (res) {
          if (res.ok) {
            feedback.textContent = 'Message envoy\u00e9\u00a0! Nous vous recontacterons rapidement.';
            feedback.className = 'contact-feedback success';
            form.reset();
          } else {
            throw new Error('error');
          }
        }).catch(function () {
          feedback.textContent = 'Une erreur est survenue. Contactez-nous \u00e0 contact@mi8.be.';
          feedback.className = 'contact-feedback error';
        }).finally(function () {
          btn.disabled = false;
          btn.textContent = originalText;
        });
      });
    })();
  </script>
</Layout>
