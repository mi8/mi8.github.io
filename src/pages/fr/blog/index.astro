---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/ui';

const lang = 'fr' as const;
const posts = (await getCollection('blog-fr'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={t(lang, 'blogPage.title')} description={t(lang, 'blogPage.subtitle')} lang={lang}>
  <Nav lang={lang} path="/blog" />

  <div class="blog-header">
    <div class="container">
      <p class="section-label">{t(lang, 'blog.label')}</p>
      <h1>{t(lang, 'blogPage.heading')}</h1>
      <p class="section-subtitle">{t(lang, 'blogPage.subtitle')}</p>
    </div>
  </div>

  <section>
    <div class="container">
      <div class="blog-grid">
        {posts.map((post) => (
          <a href={`/fr/blog/${post.slug}`} class="blog-card">
            <p class="blog-card-date">
              {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="blog-card-link">{t(lang, 'blog.readMore')}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-info">
          <p class="footer-company">{t(lang, 'footer.company')}</p>
          <p>{t(lang, 'footer.address')}<br />{t(lang, 'footer.vat')}</p>
        </div>
        <div class="footer-links">
          <a href="mailto:contact@mi8.be?subject=Demande%20d%27appel%20d%C3%A9couverte">contact@mi8.be</a>
          <a href="https://www.linkedin.com/company/mi8/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/mi8" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="/fr/privacy">Confidentialit&eacute;</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{t(lang, 'footer.copyright')}</p>
      </div>
    </div>
  </footer>


</Layout>
