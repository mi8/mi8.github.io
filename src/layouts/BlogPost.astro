---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import type { Lang } from '../i18n/ui';
import { t, localePath, dateLocale } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  lang?: Lang;
  slug?: string;
  author?: string;
}

const { title, description, pubDate, lang = 'en', slug = '', author } = Astro.props;
const formattedDate = pubDate.toLocaleDateString(dateLocale(lang), {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const blogPath = slug ? `/blog/${slug}` : '/blog';

const site = Astro.site!;
const canonicalURL = new URL(Astro.url.pathname, site).href;
const articleAuthor = author || 'mi8 SRL';

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": articleAuthor,
  },
  "publisher": {
    "@type": "Organization",
    "name": "mi8 SRL",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.mi8.be/logo_dark.png",
    },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL,
  },
};
---

<Layout title={`${title} — mi8`} description={description} lang={lang} type="article" pubDate={pubDate} author={articleAuthor}>
  <Nav lang={lang} path={blogPath} />

  <article class="blog-post">
    <div class="container">
      <a href={localePath(lang, '/blog')} class="blog-back">{t(lang, 'blog.backToBlog')}</a>
      <header class="blog-post-header">
        <p class="blog-post-meta">{formattedDate}</p>
        <h1>{title}</h1>
      </header>
      <div class="blog-post-content">
        <slot />
      </div>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-info">
          <p class="footer-company">{t(lang, 'footer.company')}</p>
          <p>{t(lang, 'footer.address')}<br />{t(lang, 'footer.vat')}</p>
        </div>
        <div class="footer-links">
          <a href="mailto:contact@mi8.be?subject=Discovery%20call%20request">contact@mi8.be</a>
          <a href="https://www.linkedin.com/company/mi8/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/mi8" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{t(lang, 'footer.copyright')}</p>
      </div>
    </div>
  </footer>


</Layout>
