---
import Layout from './Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import type { Lang } from '../i18n/ui';
import { t, localePath, dateLocale } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  lang?: Lang;
  slug?: string;
}

const { title, description, pubDate, lang = 'en', slug = '' } = Astro.props;
const formattedDate = pubDate.toLocaleDateString(dateLocale(lang), {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const blogPath = slug ? `/blog/${slug}` : '/blog';
---

<Layout title={`${title} — mi8`} description={description} lang={lang}>
  <nav class="nav">
    <div class="container">
      <a href={localePath(lang, '/')} class="nav-logo">
        <img src="/logo_dark.svg" alt="mi8" width="48" height="32" class="logo-light-theme" />
        <img src="/logo_light.svg" alt="mi8" width="48" height="32" class="logo-dark-theme" />
      </a>
      <ul class="nav-links">
        <li><a href={localePath(lang, '/#services')}>{t(lang, 'nav.services')}</a></li>
        <li><a href={localePath(lang, '/#use-cases')}>{t(lang, 'nav.useCases')}</a></li>
        <li><a href={localePath(lang, '/#sovereignty')}>{t(lang, 'nav.approach')}</a></li>
        <li><a href={localePath(lang, '/blog')}>{t(lang, 'nav.blog')}</a></li>
        <li><a href={localePath(lang, '/assessment')}>{t(lang, 'assessment.nav')}</a></li>
      </ul>
      <div class="nav-right">
        <LanguagePicker lang={lang} path={blogPath} />
        <ThemeToggle />
        <a href={localePath(lang, '/#contact')} class="btn btn-primary">{t(lang, 'nav.cta')}</a>
      </div>
    </div>
  </nav>

  <article class="blog-post">
    <div class="container">
      <a href={localePath(lang, '/blog')} class="blog-back">{t(lang, 'blog.backToBlog')}</a>
      <header class="blog-post-header">
        <p class="blog-post-meta">{formattedDate}</p>
        <h1>{title}</h1>
      </header>
      <div class="blog-post-content">
        <slot />
      </div>
    </div>
  </article>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-info">
          <p class="footer-company">{t(lang, 'footer.company')}</p>
          <p>{t(lang, 'footer.address')}<br />{t(lang, 'footer.vat')}</p>
        </div>
        <div class="footer-links">
          <a href="mailto:contact@mi8.be?subject=Discovery%20call%20request">contact@mi8.be</a>
          <a href="https://www.linkedin.com/company/mi8/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/mi8" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{t(lang, 'footer.copyright')}</p>
      </div>
    </div>
  </footer>
</Layout>
